# ─────────────────────────────────────────────────────────────
# PRODUCTION .env  —  copy this file to .env on your VPS
# Run: cp .env.production.example .env  then fill in values
# ─────────────────────────────────────────────────────────────

# MySQL credentials from Hostinger hPanel → Databases → MySQL Databases
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME"

# Generate with:  openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
NEXTAUTH_SECRET="SAME_AS_AUTH_SECRET"
NEXTAUTH_URL="https://yourdomain.com"

# Public app config
NEXT_PUBLIC_APP_NAME="DoorTrack"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Feature flags
NEXT_PUBLIC_PHOTO_CAPTURE_ENABLED="false"
GPS_MAX_ACCURACY_METERS="100"

# Node environment
NODE_ENV="production"
