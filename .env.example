# Database - update with your Hostinger MySQL credentials
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/doortodoor_db"

# NextAuth - generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://yourdomain.com"

# App
NEXT_PUBLIC_APP_NAME="DoorTrack"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Feature Flags
# Set to "true" to require agents to take a selfie on punch-in
NEXT_PUBLIC_PHOTO_CAPTURE_ENABLED="false"

# GPS anti-spoofing: flag readings with accuracy worse than this value (meters)
GPS_MAX_ACCURACY_METERS="100"
